<Application
    x:Class="NextGenEmby.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <muxc:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="AppBackgroundColor">#0B0F14</Color>
            <Color x:Key="AppSurfaceColor">#111821</Color>
            <Color x:Key="AppRaisedSurfaceColor">#172231</Color>
            <Color x:Key="AppAccentColor">#00A6D6</Color>
            <Color x:Key="AppMutedTextColor">#B7C6D8</Color>
            <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
            <SolidColorBrush x:Key="AppRaisedSurfaceBrush" Color="{StaticResource AppRaisedSurfaceColor}" />
            <SolidColorBrush x:Key="AppAccentBrush" Color="{StaticResource AppAccentColor}" />
            <SolidColorBrush x:Key="AppMutedTextBrush" Color="{StaticResource AppMutedTextColor}" />
            <SolidColorBrush x:Key="SystemControlFocusVisualPrimaryBrush" Color="#FFFFFFFF" />
            <SolidColorBrush x:Key="SystemControlFocusVisualSecondaryBrush" Color="{StaticResource AppAccentColor}" />

            <Style TargetType="Button">
                <Setter Property="MinHeight" Value="64" />
                <Setter Property="MinWidth" Value="220" />
                <Setter Property="Padding" Value="28,12" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="MinHeight" Value="64" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
            </Style>

            <Style TargetType="PasswordBox">
                <Setter Property="MinHeight" Value="64" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="Padding" Value="18,10" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
            </Style>

            <Style TargetType="muxc:NavigationViewItem">
                <Setter Property="MinHeight" Value="68" />
                <Setter Property="FontSize" Value="20" />
                <Setter Property="UseSystemFocusVisuals" Value="True" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
