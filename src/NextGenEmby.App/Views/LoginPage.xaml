<Page
    x:Class="NextGenEmby.App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="72,60" MaxWidth="1040" HorizontalAlignment="Left">
                <StackPanel Spacing="28">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Next Gen Xbox Emby" FontSize="46" FontWeight="SemiBold" />
                    </StackPanel>

                    <Grid RowSpacing="18" MaxWidth="720">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBox Grid.Row="0" Header="Server URL" PlaceholderText="http://emby.local:8096" />
                        <TextBox Grid.Row="1" Header="Username" PlaceholderText="emby user" />
                        <PasswordBox Grid.Row="2" Header="Password or API token" PasswordRevealMode="Hidden" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="18">
                        <Button Content="Connect" IsEnabled="False" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
