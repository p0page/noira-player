<Page
    x:Class="NextGenEmby.App.Views.MusicPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid Margin="{StaticResource TvPageMargin}" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource TvPageTitleTextStyle}"
                        Text="Music" />
                    <TextBlock
                        x:Name="StatusBlock"
                        Style="{StaticResource TvPageSubtitleTextStyle}"
                        Text="Loading music" />
                </StackPanel>

                <Button
                    x:Name="RefreshButton"
                    Grid.Column="1"
                    AutomationProperties.Name="Refresh music"
                    Click="RefreshButton_OnClick"
                    Style="{StaticResource IconButtonStyle}">
                    <SymbolIcon Symbol="Refresh" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="400" />
                    <ColumnDefinition Width="440" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="3">
                        <TextBlock
                            Style="{StaticResource TvSectionTitleTextStyle}"
                            Text="Artists" />
                        <TextBlock
                            x:Name="ArtistsCountBlock"
                            Style="{StaticResource TvMutedBodyTextStyle}"
                            Text="Loading" />
                    </StackPanel>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Hidden"
                        VerticalScrollMode="Enabled">
                        <StackPanel
                            x:Name="ArtistsPanel"
                            Spacing="10" />
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Column="1" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Spacing="3">
                        <TextBlock
                            Style="{StaticResource TvSectionTitleTextStyle}"
                            Text="Albums" />
                        <TextBlock
                            x:Name="AlbumsCountBlock"
                            Style="{StaticResource TvMutedBodyTextStyle}"
                            Text="Loading" />
                    </StackPanel>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Hidden"
                        VerticalScrollMode="Enabled">
                        <StackPanel
                            x:Name="AlbumsPanel"
                            Spacing="10" />
                    </ScrollViewer>
                </Grid>

                <Grid Grid.Column="2" RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="3">
                            <TextBlock
                                x:Name="SongsTitleBlock"
                                Style="{StaticResource TvSectionTitleTextStyle}"
                                Text="Songs" />
                            <TextBlock
                                x:Name="SongsCountBlock"
                                Style="{StaticResource TvMutedBodyTextStyle}"
                                Text="Loading" />
                        </StackPanel>

                        <Button
                            x:Name="AllSongsButton"
                            Grid.Column="1"
                            AutomationProperties.Name="Show all songs"
                            Click="AllSongsButton_OnClick"
                            Style="{StaticResource TvNavButtonStyle}"
                            Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="List" />
                                <TextBlock Text="All" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Disabled"
                        HorizontalScrollMode="Disabled"
                        VerticalScrollBarVisibility="Hidden"
                        VerticalScrollMode="Enabled">
                        <StackPanel
                            x:Name="SongsPanel"
                            Spacing="10" />
                    </ScrollViewer>
                </Grid>

                <Border
                    Grid.Column="3"
                    MinHeight="260"
                    VerticalAlignment="Top"
                    Style="{StaticResource TvPanelStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock
                            x:Name="PreviewBadgeBlock"
                            Style="{StaticResource TvBadgeTextStyle}"
                            Text="Now" />
                        <Border
                            x:Name="PreviewArtworkFrame"
                            Width="220"
                            Height="220"
                            HorizontalAlignment="Left"
                            Background="{StaticResource AppRaisedSurfaceBrush}"
                            BorderBrush="{StaticResource AppTransparentBrush}"
                            BorderThickness="0"
                            CornerRadius="{StaticResource TvHomeWideCardCornerRadius}"
                            Visibility="Collapsed">
                            <Image
                                x:Name="PreviewArtworkImage"
                                Stretch="UniformToFill" />
                        </Border>
                        <TextBlock
                            x:Name="PreviewTitleBlock"
                            Style="{StaticResource TvPanelTitleTextStyle}"
                            Text="Select music" />
                        <TextBlock
                            x:Name="PreviewBodyBlock"
                            Style="{StaticResource TvMutedBodyTextStyle}"
                            Text="Albums and songs appear here when the server exposes a music library." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:Name="FallbackPanel"
            Background="{StaticResource AppImmersiveScrimBrush}"
            Visibility="Collapsed">
            <Border
                MaxWidth="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource TvPanelStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Name="FallbackTitleBlock"
                        Style="{StaticResource TvPanelTitleTextStyle}"
                        Text="Music unavailable"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="FallbackBodyBlock"
                        Style="{StaticResource TvMutedBodyTextStyle}"
                        Text="This server did not return music items."
                        TextAlignment="Center" />
                    <Button
                        x:Name="FallbackRetryButton"
                        HorizontalAlignment="Center"
                        AutomationProperties.Name="Retry music"
                        Click="RefreshButton_OnClick"
                        Style="{StaticResource TvLibraryOptionSheetOptionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock Text="Retry" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            x:Name="UnsupportedPanel"
            Background="{StaticResource AppImmersiveScrimBrush}"
            Visibility="Collapsed">
            <Border
                Style="{StaticResource TvTransientMessagePanelStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Name="UnsupportedTitleBlock"
                        Style="{StaticResource TvPanelTitleTextStyle}"
                        Text="Music playback unavailable"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="UnsupportedBodyBlock"
                        Style="{StaticResource TvMutedBodyTextStyle}"
                        Text="Music browsing is available, but this build does not start audio playback yet."
                        TextAlignment="Center" />
                    <Button
                        x:Name="UnsupportedCloseButton"
                        HorizontalAlignment="Center"
                        AutomationProperties.Name="Close music message"
                        Click="UnsupportedCloseButton_OnClick"
                        Style="{StaticResource TvLibraryOptionSheetOptionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Back" />
                            <TextBlock Text="Close" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
