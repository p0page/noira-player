<Page
    x:Class="NextGenEmby.App.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid Margin="{StaticResource TvPageMargin}" RowSpacing="14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="TitleBlock"
                        Style="{StaticResource TvPageTitleTextStyle}"
                        Text="Library"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="StatusBlock"
                        Style="{StaticResource TvMutedBodyTextStyle}" />
                </StackPanel>

                <Button
                    x:Name="RefreshButton"
                    Grid.Column="1"
                    AutomationProperties.Name="Refresh"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="Refresh_OnClick"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTipService.ToolTip="Refresh"
                    UseSystemFocusVisuals="True">
                    <SymbolIcon Symbol="Refresh" />
                </Button>
            </Grid>

            <StackPanel
                x:Name="OptionsPanel"
                Grid.Row="1"
                Orientation="Horizontal"
                Spacing="18">
                <StackPanel Width="220" Spacing="6">
                    <TextBlock
                        Style="{StaticResource TvOptionLabelTextStyle}"
                        Text="Sort" />
                    <Button
                        x:Name="SortButton"
                        AutomationProperties.Name="Sort"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Click="SortButton_OnClick">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="SortValueBlock"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="Title"
                                TextTrimming="CharacterEllipsis" />
                            <SymbolIcon
                                Grid.Column="1"
                                Symbol="Sort"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>

                <StackPanel Width="220" Spacing="6">
                    <TextBlock
                        Style="{StaticResource TvOptionLabelTextStyle}"
                        Text="Filter" />
                    <Button
                        x:Name="FilterButton"
                        AutomationProperties.Name="Filter"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Stretch"
                        Click="FilterButton_OnClick">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                x:Name="FilterValueBlock"
                                VerticalAlignment="Center"
                                FontSize="16"
                                Text="All"
                                TextTrimming="CharacterEllipsis" />
                            <SymbolIcon
                                Grid.Column="1"
                                Symbol="Filter"
                                VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>
            </StackPanel>

            <Grid Grid.Row="2">
                <GridView
                    x:Name="ItemsGrid"
                    IsItemClickEnabled="True"
                    ItemClick="ItemsGrid_OnItemClick"
                    SelectionMode="None"
                    Margin="0,8,0,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                    <GridView.ItemContainerStyle>
                        <Style TargetType="GridViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="UseSystemFocusVisuals" Value="True" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,14,14" />
                        </Style>
                    </GridView.ItemContainerStyle>
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Width="168"
                                Height="250"
                                Background="{StaticResource AppRaisedSurfaceBrush}">
                                <Grid.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource AppTextBrush}" />
                                    </Style>
                                </Grid.Resources>
                                <Border
                                    BorderBrush="{StaticResource AppHairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6" />
                                <Image
                                    Source="{Binding ImageSource}"
                                    Stretch="UniformToFill" />
                                <Border Background="{StaticResource AppArtworkDimBrush}" />
                                <Border
                                    VerticalAlignment="Bottom"
                                    Background="{StaticResource AppCardScrimBrush}"
                                    Padding="14,12">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="{Binding Title}"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis"
                                            MaxLines="2"
                                            TextWrapping="WrapWholeWords" />
                                        <TextBlock
                                            Text="{Binding Meta}"
                                            FontSize="13"
                                            Foreground="{StaticResource AppMutedTextBrush}"
                                            TextTrimming="CharacterEllipsis"
                                            MaxLines="1" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid
                                Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>

                <StackPanel
                    x:Name="EmptyStatePanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="560"
                    Spacing="18"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="EmptyTitleBlock"
                        HorizontalAlignment="Center"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="No items found"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="EmptyBodyBlock"
                        HorizontalAlignment="Center"
                        FontSize="17"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        Text="Try another filter or refresh this library."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="14">
                        <Button
                            x:Name="ClearFiltersButton"
                            Click="ClearFilters_OnClick"
                            Content="Clear filters" />
                        <Button
                            x:Name="EmptyRetryButton"
                            Click="Refresh_OnClick"
                            Content="Retry" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid
            x:Name="OptionSheetRoot"
            Canvas.ZIndex="20"
            Background="{StaticResource AppModalScrimBrush}"
            Visibility="Collapsed">
            <Grid Margin="{StaticResource TvPageMargin}">
                <Border
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Width="720"
                    Background="{StaticResource AppSurfaceBrush}"
                    BorderBrush="{StaticResource AppHairlineBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                    <StackPanel Spacing="16">
                        <StackPanel Spacing="4">
                            <TextBlock
                                x:Name="OptionSheetTitleBlock"
                                FontSize="30"
                                FontWeight="SemiBold"
                                Text="Sort" />
                            <TextBlock
                                x:Name="OptionSheetSubtitleBlock"
                                FontSize="16"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                Text="Choose an option" />
                        </StackPanel>

                        <StackPanel
                            x:Name="OptionSheetOptionsPanel"
                            Spacing="10" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
