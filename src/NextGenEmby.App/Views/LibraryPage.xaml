<Page
    x:Class="NextGenEmby.App.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="72,48">
                <StackPanel Spacing="22">
                    <TextBlock
                        x:Name="TitleBlock"
                        FontSize="46"
                        FontWeight="SemiBold"
                        Text="Library" />
                    <TextBlock
                        x:Name="StatusBlock"
                        MaxWidth="760"
                        HorizontalAlignment="Left"
                        FontSize="20"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        Text="Library browsing will be wired to Emby in a later task."
                        TextWrapping="Wrap" />
                    <Grid ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="260" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Height="170" Background="{StaticResource AppRaisedSurfaceBrush}" CornerRadius="8" Padding="22">
                            <TextBlock VerticalAlignment="Bottom" FontSize="24" FontWeight="SemiBold" Text="Recently Added" TextWrapping="Wrap" />
                        </Border>
                        <Border Grid.Column="1" Height="170" Background="{StaticResource AppRaisedSurfaceBrush}" CornerRadius="8" Padding="22">
                            <TextBlock VerticalAlignment="Bottom" FontSize="24" FontWeight="SemiBold" Text="Continue Watching" TextWrapping="Wrap" />
                        </Border>
                        <Border Grid.Column="2" Height="170" Background="{StaticResource AppRaisedSurfaceBrush}" CornerRadius="8" Padding="22">
                            <TextBlock VerticalAlignment="Bottom" FontSize="24" FontWeight="SemiBold" Text="Genres" TextWrapping="Wrap" />
                        </Border>
                    </Grid>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
