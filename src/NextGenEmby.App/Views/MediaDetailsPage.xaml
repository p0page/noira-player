<Page
    x:Class="NextGenEmby.App.Views.MediaDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <Image
            x:Name="BackdropImage"
            Stretch="UniformToFill"
            Opacity="0.35" />
        <Border Background="#D80E141F" />

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="72,60" ColumnSpacing="44">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border
                    Width="320"
                    Height="480"
                    Background="{StaticResource AppRaisedSurfaceBrush}"
                    CornerRadius="8">
                    <Grid>
                        <Image
                            x:Name="PosterImage"
                            Stretch="UniformToFill" />
                        <TextBlock
                            x:Name="PosterFallbackBlock"
                            Text="No image"
                            FontSize="22"
                            Foreground="{StaticResource AppMutedTextBrush}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <StackPanel
                    Grid.Column="1"
                    MaxWidth="900"
                    Spacing="24">
                    <StackPanel Spacing="8">
                        <TextBlock
                            x:Name="TitleBlock"
                            FontSize="52"
                            FontWeight="SemiBold"
                            TextWrapping="WrapWholeWords" />
                        <TextBlock
                            x:Name="MetaBlock"
                            FontSize="22"
                            Foreground="{StaticResource AppMutedTextBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Button
                            x:Name="PlayButton"
                            MinWidth="220"
                            Height="68"
                            Click="Play_OnClick"
                            UseSystemFocusVisuals="True">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <SymbolIcon Symbol="Play" />
                                <TextBlock
                                    x:Name="PlayButtonText"
                                    Text="Play"
                                    FontSize="24" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="RefreshButton"
                            Width="68"
                            Height="68"
                            MinWidth="68"
                            Click="Refresh_OnClick"
                            ToolTipService.ToolTip="Refresh"
                            UseSystemFocusVisuals="True">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                    </StackPanel>

                    <StackPanel
                        x:Name="VersionsPanel"
                        Spacing="10" />

                    <TextBlock
                        x:Name="AudioSummaryBlock"
                        FontSize="20"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        x:Name="SubtitleSummaryBlock"
                        FontSize="20"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        TextWrapping="Wrap" />

                    <StackPanel
                        x:Name="EpisodesSection"
                        Spacing="14"
                        Visibility="Collapsed">
                        <TextBlock
                            Text="Episodes"
                            FontSize="26"
                            FontWeight="SemiBold" />
                        <StackPanel
                            x:Name="EpisodesPanel"
                            Spacing="10" />
                    </StackPanel>

                    <TextBlock
                        x:Name="OverviewBlock"
                        FontSize="24"
                        LineHeight="34"
                        TextWrapping="WrapWholeWords"
                        MaxWidth="860" />

                    <TextBlock
                        x:Name="StatusBlock"
                        FontSize="20"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
