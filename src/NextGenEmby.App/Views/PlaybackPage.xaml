<Page
    x:Class="NextGenEmby.App.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">
    <Grid Background="Black">
        <MediaPlayerElement
            x:Name="PlayerElement"
            AreTransportControlsEnabled="False"
            Stretch="Uniform" />
        <SwapChainPanel
            x:Name="NativeSurface"
            Visibility="Collapsed" />

        <Border
            VerticalAlignment="Bottom"
            Background="#D9000000"
            Padding="48,32">
            <Grid RowSpacing="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" ColumnSpacing="24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        x:Name="StreamUrlBox"
                        Grid.Column="0"
                        Header="Direct stream URL"
                        PlaceholderText="http://server:8096/Videos/item/stream"
                        TextChanged="StreamUrlBox_OnTextChanged" />

                    <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="4">
                        <TextBlock
                            Text="State"
                            FontSize="14"
                            Foreground="{StaticResource AppMutedTextBrush}" />
                        <TextBlock
                            x:Name="StatusBlock"
                            FontSize="24"
                            FontWeight="SemiBold"
                            Text="Stopped"
                            TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Grid>

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <Button
                            x:Name="StartButton"
                            MinWidth="160"
                            Click="Start_OnClick"
                            ToolTipService.ToolTip="Play direct stream">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Play" />
                                <TextBlock Text="Play" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="PauseButton"
                            MinWidth="160"
                            Click="Pause_OnClick"
                            ToolTipService.ToolTip="Pause playback">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Pause" />
                                <TextBlock Text="Pause" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="ResumeButton"
                            MinWidth="170"
                            Click="Resume_OnClick"
                            ToolTipService.ToolTip="Resume playback">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Play" />
                                <TextBlock Text="Resume" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="StopButton"
                            MinWidth="150"
                            Click="Stop_OnClick"
                            ToolTipService.ToolTip="Stop playback">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Stop" />
                                <TextBlock Text="Stop" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="SeekBackButton"
                            MinWidth="140"
                            Click="SeekBack_OnClick"
                            ToolTipService.ToolTip="Seek backward ten seconds">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Back" />
                                <TextBlock Text="10s" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="SeekForwardButton"
                            MinWidth="140"
                            Click="SeekForward_OnClick"
                            ToolTipService.ToolTip="Seek forward thirty seconds">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Forward" />
                                <TextBlock Text="30s" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="InfoButton"
                            MinWidth="140"
                            Click="Info_OnClick"
                            ToolTipService.ToolTip="Show playback information">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Help" />
                                <TextBlock Text="Info" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer
                    Grid.Row="2"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <ComboBox
                            x:Name="SourceBox"
                            Width="280"
                            Header="Source"
                            SelectionChanged="SourceBox_OnSelectionChanged" />
                        <ComboBox
                            x:Name="AudioStreamBox"
                            Width="280"
                            Header="Audio"
                            SelectionChanged="AudioStreamBox_OnSelectionChanged" />
                        <ComboBox
                            x:Name="SubtitleStreamBox"
                            Width="280"
                            Header="Subtitles"
                            SelectionChanged="SubtitleStreamBox_OnSelectionChanged" />
                    </StackPanel>
                </ScrollViewer>

                <Border
                    x:Name="InfoPanel"
                    Grid.Row="3"
                    Background="{StaticResource AppSurfaceBrush}"
                    Padding="18"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="InfoBlock"
                        FontSize="18"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
