<Page
    x:Class="NextGenEmby.App.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Black">
    <Grid
        Background="Black"
        KeyDown="Page_OnKeyDown"
        PointerPressed="Page_OnPointerPressed">
        <MediaPlayerElement
            x:Name="PlayerElement"
            AreTransportControlsEnabled="False"
            Canvas.ZIndex="0"
            Stretch="Uniform" />
        <SwapChainPanel
            x:Name="NativeSurface"
            Canvas.ZIndex="0"
            Visibility="Collapsed" />

        <Grid
            x:Name="OverlayRoot"
            Background="Transparent"
            Canvas.ZIndex="10"
            Visibility="Collapsed">
            <Border
                VerticalAlignment="Bottom"
                Background="#D9000000"
                Padding="40,22">
                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="220" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="8">
                            <TextBlock
                                x:Name="NowPlayingBlock"
                                FontSize="24"
                                FontWeight="SemiBold"
                                Text="Now Playing"
                                TextTrimming="CharacterEllipsis" />
                            <Slider
                                x:Name="ProgressSlider"
                                IsEnabled="False"
                                Maximum="1"
                                Minimum="0"
                                Value="0"
                                ValueChanged="ProgressSlider_OnValueChanged" />
                            <TextBlock
                                x:Name="SeekPreviewBlock"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                FontSize="16"
                                TextTrimming="CharacterEllipsis"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Spacing="4">
                            <TextBlock
                                Text="State"
                                FontSize="12"
                                Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock
                                x:Name="StatusBlock"
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="Stopped"
                                TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                    </Grid>

                    <ScrollViewer
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button
                                x:Name="PauseButton"
                                AutomationProperties.Name="Pause"
                                MinWidth="122"
                                Click="Pause_OnClick"
                                ToolTipService.ToolTip="Pause playback">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Pause" />
                                    <TextBlock Text="Pause" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="ResumeButton"
                                AutomationProperties.Name="Resume"
                                MinWidth="132"
                                Click="Resume_OnClick"
                                ToolTipService.ToolTip="Resume playback">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="Resume" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="SeekBackButton"
                                AutomationProperties.Name="Seek back 10 seconds"
                                MinWidth="96"
                                Click="SeekBack_OnClick"
                                ToolTipService.ToolTip="Seek backward ten seconds">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Back" />
                                    <TextBlock Text="10s" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="SeekForwardButton"
                                AutomationProperties.Name="Seek forward 30 seconds"
                                MinWidth="96"
                                Click="SeekForward_OnClick"
                                ToolTipService.ToolTip="Seek forward thirty seconds">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Forward" />
                                    <TextBlock Text="30s" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="MoreButton"
                                AutomationProperties.Name="More"
                                MinWidth="112"
                                Click="More_OnClick"
                                ToolTipService.ToolTip="More playback controls">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="More" />
                                    <TextBlock Text="More" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="StopButton"
                                AutomationProperties.Name="Stop"
                                MinWidth="112"
                                Click="Stop_OnClick"
                                ToolTipService.ToolTip="Stop playback">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Stop" />
                                    <TextBlock Text="Stop" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>

                    <Border
                        x:Name="ManualDebugPanel"
                        Grid.Row="2"
                        Background="{StaticResource AppSurfaceBrush}"
                        Padding="14"
                        Visibility="Collapsed">
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                x:Name="StreamUrlBox"
                                Header="Direct stream URL"
                                PlaceholderText="http://server:8096/Videos/item/stream"
                                TextChanged="StreamUrlBox_OnTextChanged" />
                            <Button
                                x:Name="ManualStartButton"
                                Grid.Column="1"
                                AutomationProperties.Name="Play direct stream"
                                MinWidth="112"
                                VerticalAlignment="Bottom"
                                Click="Start_OnClick"
                                ToolTipService.ToolTip="Play direct stream">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="Play" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border
                x:Name="MoreDrawer"
                Width="370"
                HorizontalAlignment="Right"
                Background="#F0000000"
                Padding="22"
                Visibility="Collapsed">
                <ScrollViewer>
                    <StackPanel Spacing="14">
                        <TextBlock
                            Text="Playback Options"
                            FontSize="22"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis" />
                        <ComboBox
                            x:Name="SourceBox"
                            HorizontalAlignment="Stretch"
                            Header="Source"
                            SelectionChanged="SourceBox_OnSelectionChanged" />
                        <ComboBox
                            x:Name="AudioStreamBox"
                            HorizontalAlignment="Stretch"
                            Header="Audio"
                            SelectionChanged="AudioStreamBox_OnSelectionChanged" />
                        <ComboBox
                            x:Name="SubtitleStreamBox"
                            HorizontalAlignment="Stretch"
                            Header="Subtitles"
                            SelectionChanged="SubtitleStreamBox_OnSelectionChanged" />
                        <Button
                            x:Name="InfoButton"
                            AutomationProperties.Name="Info"
                            HorizontalAlignment="Stretch"
                            Click="Info_OnClick"
                            ToolTipService.ToolTip="Show playback information">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Help" />
                                <TextBlock Text="Info" />
                            </StackPanel>
                        </Button>
                        <Border
                            x:Name="InfoPanel"
                            Background="{StaticResource AppSurfaceBrush}"
                            Padding="14"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="InfoBlock"
                                FontSize="15"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
