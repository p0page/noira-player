<Page
    x:Class="NextGenEmby.App.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid Margin="{StaticResource TvPageMargin}" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="4">
                <TextBlock
                    Text="Search"
                    Style="{StaticResource TvPageTitleTextStyle}" />
                <TextBlock
                    Text="Across libraries"
                    Style="{StaticResource TvMutedBodyTextStyle}" />
            </StackPanel>

            <Border
                Grid.Row="1"
                Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppHairlineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="SearchBox"
                        AutomationProperties.Name="Search title"
                        PlaceholderText="Title, person, playlist, music"
                        KeyDown="SearchBox_OnKeyDown"
                        UseSystemFocusVisuals="True" />
                    <Button
                        x:Name="SearchActionButton"
                        Grid.Column="1"
                        MinWidth="146"
                        Click="Search_OnClick"
                        UseSystemFocusVisuals="True">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Find" />
                            <TextBlock Text="Search" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <ScrollViewer
                Grid.Row="2"
                HorizontalScrollBarVisibility="Hidden"
                HorizontalScrollMode="Enabled"
                VerticalScrollBarVisibility="Disabled"
                VerticalScrollMode="Disabled">
                <StackPanel
                    x:Name="ScopesPanel"
                    Orientation="Horizontal"
                    Spacing="12" />
            </ScrollViewer>

            <TextBlock
                x:Name="StatusBlock"
                Grid.Row="3"
                Style="{StaticResource TvStatusTextStyle}"
                Text="Enter a search." />

            <Grid Grid.Row="4">
                <GridView
                    x:Name="ResultsGrid"
                    IsItemClickEnabled="True"
                    ItemClick="ResultsGrid_OnItemClick"
                    SelectionMode="None"
                    ItemContainerStyle="{StaticResource TvPosterGridItemStyle}"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Grid
                                Width="{StaticResource TvPosterCardWidth}"
                                Height="{StaticResource TvPosterCardHeight}"
                                Background="{StaticResource AppRaisedSurfaceBrush}">
                                <Border
                                    BorderBrush="{StaticResource AppHairlineBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource TvPosterCardCornerRadius}" />
                                <TextBlock
                                    Text="{Binding Initials}"
                                    Style="{StaticResource TvPosterFallbackInitialsTextStyle}" />
                                <Image
                                    Source="{Binding ImageSource}"
                                    Stretch="UniformToFill" />
                                <Border Background="{StaticResource AppArtworkDimBrush}" />
                                <Border
                                    VerticalAlignment="Bottom"
                                    Background="{StaticResource AppCardScrimBrush}"
                                    Padding="{StaticResource TvPosterCardScrimPadding}">
                                    <StackPanel Spacing="4">
                                        <TextBlock
                                            Text="{Binding Title}"
                                            Style="{StaticResource TvPosterCardTitleTextStyle}" />
                                        <TextBlock
                                            Text="{Binding Meta}"
                                            Style="{StaticResource TvPosterCardMetaTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                    <GridView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ItemsWrapGrid Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </GridView.ItemsPanel>
                </GridView>

                <StackPanel
                    x:Name="EmptyStatePanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MaxWidth="560"
                    Spacing="18"
                    Visibility="Collapsed">
                    <TextBlock
                        x:Name="EmptyTitleBlock"
                        Style="{StaticResource TvEmptyStateTitleTextStyle}"
                        Text="No results" />
                    <TextBlock
                        x:Name="EmptyBodyBlock"
                        Style="{StaticResource TvEmptyStateBodyTextStyle}"
                        Text="Try a different title, person, playlist, or song." />
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="14">
                        <Button
                            x:Name="EmptyEditButton"
                            Click="EmptyEdit_OnClick"
                            Content="Edit search" />
                        <Button
                            x:Name="EmptyRetryButton"
                            Click="EmptyRetry_OnClick"
                            Content="Search again" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
