<Page
    x:Class="NextGenEmby.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid
                Margin="{StaticResource TvPageMargin}"
                MaxWidth="{StaticResource TvSettingsContentMaxWidth}"
                HorizontalAlignment="Left">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Settings" Style="{StaticResource TvPageTitleTextStyle}" />
                        <TextBlock
                            Text="Account, input, and diagnostics"
                            Style="{StaticResource TvPageSubtitleTextStyle}" />
                    </StackPanel>

                    <Border Style="{StaticResource TvPanelStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Account" Style="{StaticResource TvPanelTitleTextStyle}" />
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Session" Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="AccountBlock"
                                    Grid.Column="1"
                                    Style="{StaticResource TvBodyValueTextStyle}"
                                    Text="Not signed in"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="Version"
                                    Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="VersionBlock"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource TvBodyValueTextStyle}" />

                                <Button
                                    x:Name="SignOutButton"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    AutomationProperties.Name="Sign out of Emby"
                                    Click="SignOutButton_OnClick"
                                    Content="Sign out"
                                    Style="{StaticResource TvUtilityCommandButtonStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TvPanelStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Playback input" Style="{StaticResource TvPanelTitleTextStyle}" />
                            <CheckBox
                                x:Name="ThumbstickSeekPreviewCheckBox"
                                Content="Thumbstick seek preview"
                                IsEnabled="True"
                                Checked="ThumbstickSeekPreviewCheckBox_OnChanged"
                                Unchecked="ThumbstickSeekPreviewCheckBox_OnChanged"
                                Style="{StaticResource TvUtilityCheckBoxStyle}" />
                            <TextBlock
                                x:Name="ThumbstickSeekPreviewStatusBlock"
                                Style="{StaticResource TvMutedBodyTextStyle}" />
                            <TextBlock
                                x:Name="InputMapBlock"
                                Style="{StaticResource TvMutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TvDiagnosticsPanelStyle}">
                        <StackPanel Spacing="12">
                            <TextBlock
                                Text="Diagnostics"
                                Style="{StaticResource TvOptionLabelTextStyle}" />
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Startup" Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="StartupDiagnosticsBlock"
                                    Grid.Column="1"
                                    Style="{StaticResource TvBodyValueTextStyle}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="Recent log"
                                    Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="StartupDiagnosticsTailBlock"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource TvDiagnosticsTextStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border
            x:Name="SignOutConfirmLayer"
            Background="{StaticResource AppModalScrimBrush}"
            Visibility="Collapsed">
            <Border
                Width="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource TvPanelStyle}">
                <StackPanel Spacing="16">
                    <TextBlock Text="Sign out?" Style="{StaticResource TvPanelTitleTextStyle}" />
                    <TextBlock
                        Text="This device will forget the saved Emby session."
                        Style="{StaticResource TvMutedBodyTextStyle}" />
                    <StackPanel
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            x:Name="CancelSignOutButton"
                            AutomationProperties.Name="Keep signed in"
                            Click="CancelSignOutButton_OnClick"
                            Content="Keep signed in"
                            Style="{StaticResource TvUtilityCommandButtonStyle}" />
                        <Button
                            x:Name="ConfirmSignOutButton"
                            AutomationProperties.Name="Confirm sign out"
                            Click="ConfirmSignOutButton_OnClick"
                            Content="Sign out"
                            Style="{StaticResource TvUtilityDangerButtonStyle}" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Page>
