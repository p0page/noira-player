<Page
    x:Class="NextGenEmby.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid
                Margin="{StaticResource TvPageMargin}"
                MaxWidth="{StaticResource TvSettingsContentMaxWidth}"
                HorizontalAlignment="Left">
                <StackPanel Spacing="18">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Settings" Style="{StaticResource TvPageTitleTextStyle}" />
                        <TextBlock
                            Text="Account, input, and diagnostics"
                            Style="{StaticResource TvPageSubtitleTextStyle}" />
                    </StackPanel>

                    <Border Style="{StaticResource TvPanelStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Account" Style="{StaticResource TvPanelTitleTextStyle}" />
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Session" Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="AccountBlock"
                                    Grid.Column="1"
                                    Style="{StaticResource TvBodyValueTextStyle}"
                                    Text="Not signed in"
                                    TextWrapping="Wrap" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="Version"
                                    Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="VersionBlock"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource TvBodyValueTextStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TvPanelStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Playback input" Style="{StaticResource TvPanelTitleTextStyle}" />
                            <CheckBox
                                x:Name="ThumbstickSeekPreviewCheckBox"
                                Content="Thumbstick seek preview"
                                IsEnabled="True"
                                Checked="ThumbstickSeekPreviewCheckBox_OnChanged"
                                Unchecked="ThumbstickSeekPreviewCheckBox_OnChanged"
                                Style="{StaticResource TvSettingsCheckBoxStyle}" />
                            <TextBlock
                                x:Name="ThumbstickSeekPreviewStatusBlock"
                                Style="{StaticResource TvMutedBodyTextStyle}" />
                            <TextBlock
                                x:Name="InputMapBlock"
                                Style="{StaticResource TvMutedBodyTextStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TvPanelStyle}">
                        <StackPanel Spacing="14">
                            <TextBlock Text="Diagnostics" Style="{StaticResource TvPanelTitleTextStyle}" />
                            <Grid ColumnSpacing="18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="Startup" Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="StartupDiagnosticsBlock"
                                    Grid.Column="1"
                                    Style="{StaticResource TvBodyValueTextStyle}" />

                                <TextBlock
                                    Grid.Row="1"
                                    Text="Recent log"
                                    Style="{StaticResource TvFieldLabelTextStyle}" />
                                <TextBlock
                                    x:Name="StartupDiagnosticsTailBlock"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    Style="{StaticResource TvDiagnosticsTextStyle}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
