<Page
    x:Class="NextGenEmby.App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="72,48" MaxWidth="940" HorizontalAlignment="Left">
                <StackPanel Spacing="28">
                    <TextBlock Text="Settings" FontSize="46" FontWeight="SemiBold" />
                    <Border Background="{StaticResource AppSurfaceBrush}" CornerRadius="8" Padding="28">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Signed in" FontSize="24" FontWeight="SemiBold" />
                            <TextBlock
                                x:Name="AccountBlock"
                                FontSize="20"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                Text="Not signed in"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource AppSurfaceBrush}" CornerRadius="8" Padding="28">
                        <StackPanel Spacing="14">
                            <CheckBox
                                x:Name="ThumbstickSeekPreviewCheckBox"
                                Content="Thumbstick seek preview"
                                FontSize="22"
                                IsChecked="True"
                                IsEnabled="True"
                                UseSystemFocusVisuals="True" />
                            <TextBlock
                                FontSize="18"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                Text="Shows a preview while seeking with the controller thumbstick. The playback task will connect this setting to the player."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
