<Page
    x:Class="NextGenEmby.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid Margin="72,60">
                <StackPanel Spacing="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Home" FontSize="46" FontWeight="SemiBold" />
                        <Button
                            x:Name="RefreshButton"
                            Grid.Column="1"
                            Width="64"
                            Height="64"
                            HorizontalAlignment="Right"
                            Click="Refresh_OnClick"
                            ToolTipService.ToolTip="Refresh"
                            UseSystemFocusVisuals="True">
                            <SymbolIcon Symbol="Refresh" />
                        </Button>
                    </Grid>

                    <StackPanel Spacing="18">
                        <TextBlock Text="Libraries" FontSize="28" FontWeight="SemiBold" />
                        <Grid ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="280" />
                                <ColumnDefinition Width="280" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="280" Height="190" Background="{StaticResource AppRaisedSurfaceBrush}" CornerRadius="8" Padding="24">
                                <StackPanel VerticalAlignment="Bottom" Spacing="6">
                                    <TextBlock Text="Movies" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="Film library" FontSize="18" Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Width="280" Height="190" Background="{StaticResource AppRaisedSurfaceBrush}" CornerRadius="8" Padding="24">
                                <StackPanel VerticalAlignment="Bottom" Spacing="6">
                                    <TextBlock Text="TV Shows" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="Series library" FontSize="18" Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="2" Width="280" Height="190" Background="{StaticResource AppRaisedSurfaceBrush}" CornerRadius="8" Padding="24">
                                <StackPanel VerticalAlignment="Bottom" Spacing="6">
                                    <TextBlock Text="Music" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="Audio library" FontSize="18" Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <StackPanel Spacing="18">
                        <TextBlock Text="Latest" FontSize="28" FontWeight="SemiBold" />
                        <TextBlock
                            x:Name="StatusBlock"
                            FontSize="20"
                            Foreground="{StaticResource AppMutedTextBrush}"
                            TextWrapping="Wrap" />
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Auto"
                            HorizontalScrollMode="Enabled"
                            VerticalScrollBarVisibility="Disabled"
                            VerticalScrollMode="Disabled">
                            <StackPanel
                                x:Name="LatestItemsPanel"
                                Orientation="Horizontal"
                                Spacing="18" />
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
