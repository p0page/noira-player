<Page
    x:Class="NextGenEmby.App.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <ScrollViewer
            VerticalScrollBarVisibility="Hidden"
            VerticalScrollMode="Enabled"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled">
            <StackPanel Margin="72,42,72,64" Spacing="30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Home"
                            FontSize="42"
                            FontWeight="SemiBold" />
                        <TextBlock
                            Text="Ready for the next thing"
                            FontSize="18"
                            Foreground="{StaticResource AppMutedTextBrush}" />
                    </StackPanel>
                    <Button
                        x:Name="RefreshButton"
                        Grid.Column="1"
                        AutomationProperties.Name="Refresh"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="Refresh_OnClick"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Refresh"
                        UseSystemFocusVisuals="True">
                        <SymbolIcon Symbol="Refresh" />
                    </Button>
                </Grid>

                <Border
                    MinHeight="260"
                    Background="{StaticResource AppSurfaceBrush}"
                    CornerRadius="8"
                    Padding="28">
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="250" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Spacing="16">
                            <TextBlock
                                Text="Continue watching"
                                FontSize="20"
                                FontWeight="SemiBold"
                                Foreground="{StaticResource AppMutedTextBrush}" />
                            <TextBlock
                                x:Name="HeroTitleBlock"
                                FontSize="40"
                                FontWeight="SemiBold"
                                TextWrapping="WrapWholeWords"
                                MaxLines="2"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                x:Name="HeroMetaBlock"
                                FontSize="20"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                TextWrapping="Wrap"
                                MaxLines="2"
                                TextTrimming="WordEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Button
                                    x:Name="HeroPlayButton"
                                    MinWidth="160"
                                    Height="56"
                                    Background="{StaticResource AppActionBrush}"
                                    Click="HeroPlay_OnClick"
                                    UseSystemFocusVisuals="True">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <SymbolIcon Symbol="Play" />
                                        <TextBlock Text="Play" FontSize="20" />
                                    </StackPanel>
                                </Button>
                                <Button
                                    x:Name="HeroDetailsButton"
                                    MinWidth="170"
                                    Height="56"
                                    Click="HeroDetails_OnClick"
                                    UseSystemFocusVisuals="True">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <SymbolIcon Symbol="ContactInfo" />
                                        <TextBlock Text="Details" FontSize="20" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <Border
                            Grid.Column="1"
                            Width="250"
                            Height="210"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="{StaticResource AppRaisedSurfaceBrush}"
                            CornerRadius="8">
                            <Grid>
                                <Image
                                    x:Name="HeroPosterImage"
                                    Stretch="UniformToFill" />
                                <TextBlock
                                    x:Name="HeroPosterFallbackBlock"
                                    Text="No artwork"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Foreground="{StaticResource AppMutedTextBrush}" />
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Spacing="18">
                    <TextBlock
                        Text="Libraries"
                        FontSize="28"
                        FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <Button
                            Width="260"
                            Height="150"
                            Padding="0"
                            Click="MoviesLibrary_OnClick"
                            UseSystemFocusVisuals="True">
                            <Border
                                Background="{StaticResource AppRaisedSurfaceBrush}"
                                Padding="22"
                                CornerRadius="8">
                                <StackPanel VerticalAlignment="Bottom" Spacing="6">
                                    <TextBlock Text="Movies" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="Film library" FontSize="18" Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                        </Button>
                        <Button
                            Width="260"
                            Height="150"
                            Padding="0"
                            Click="TvLibrary_OnClick"
                            UseSystemFocusVisuals="True">
                            <Border
                                Background="{StaticResource AppRaisedSurfaceBrush}"
                                Padding="22"
                                CornerRadius="8">
                                <StackPanel VerticalAlignment="Bottom" Spacing="6">
                                    <TextBlock Text="TV" FontSize="28" FontWeight="SemiBold" />
                                    <TextBlock Text="Series library" FontSize="18" Foreground="{StaticResource AppMutedTextBrush}" />
                                </StackPanel>
                            </Border>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <TextBlock
                    x:Name="StatusBlock"
                    FontSize="20"
                    Foreground="{StaticResource AppMutedTextBrush}"
                    TextWrapping="Wrap" />

                <StackPanel
                    x:Name="RowsPanel"
                    Spacing="28" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
