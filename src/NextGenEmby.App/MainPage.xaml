<Page
    x:Class="NextGenEmby.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid>
        <muxc:NavigationView
            x:Name="ShellNav"
            Background="{StaticResource AppSurfaceBrush}"
            Header="Next Gen Xbox Emby"
            IsBackButtonVisible="Collapsed"
            IsPaneOpen="True"
            IsSettingsVisible="False"
            OpenPaneLength="300"
            PaneDisplayMode="Left"
            Margin="48,36"
            SelectionChanged="ShellNav_OnSelectionChanged"
            UseSystemFocusVisuals="True">
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem x:Name="LoginNavItem" Content="Login" Tag="login">
                    <muxc:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Contact" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Home" Tag="home">
                    <muxc:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Home" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
                <muxc:NavigationViewItem Content="Playback" Tag="playback">
                    <muxc:NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Play" />
                    </muxc:NavigationViewItem.Icon>
                </muxc:NavigationViewItem>
            </muxc:NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" />
        </muxc:NavigationView>
    </Grid>
</Page>
