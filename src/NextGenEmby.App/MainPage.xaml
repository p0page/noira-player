<Page
    x:Class="NextGenEmby.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}"
    KeyDown="Page_OnKeyDown">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="56,34,56,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                VerticalAlignment="Center"
                FontSize="28"
                FontWeight="SemiBold"
                Text="Next Gen Xbox Emby" />

            <StackPanel
                Grid.Column="1"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                Spacing="16">
                <Button x:Name="HomeButton" Content="Home" Click="Home_OnClick" />
                <Button x:Name="MoviesButton" Content="Movies" Click="Movies_OnClick" />
                <Button x:Name="TvButton" Content="TV" Click="Tv_OnClick" />
                <Button x:Name="SearchButton" Content="Search" Click="Search_OnClick" />
            </StackPanel>

            <Button
                x:Name="SettingsButton"
                Grid.Column="2"
                Width="64"
                Height="64"
                MinWidth="64"
                Padding="0"
                Click="Settings_OnClick"
                ToolTipService.ToolTip="Settings"
                UseSystemFocusVisuals="True">
                <SymbolIcon Symbol="Setting" />
            </Button>
        </Grid>

        <Frame
            x:Name="ContentFrame"
            Grid.Row="1"
            Background="{StaticResource AppBackgroundBrush}" />
    </Grid>
</Page>
