<Page
    x:Class="NextGenEmby.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Page.Resources>
        <Style x:Key="GuideButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52" />
            <Setter Property="MinHeight" Value="52" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Foreground" Value="{StaticResource AppMutedTextBrush}" />
            <Setter Property="FocusVisualMargin" Value="-3" />
            <Setter Property="FocusVisualPrimaryThickness" Value="2" />
            <Setter Property="FocusVisualSecondaryThickness" Value="1" />
            <Setter Property="UseSystemFocusVisuals" Value="True" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="GuideColumn" Width="72" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            x:Name="GuideRail"
            Grid.Column="0"
            Background="#E603060A"
            BorderBrush="{StaticResource AppHairlineBrush}"
            BorderThickness="0,0,1,0">
            <Grid Margin="8,18,8,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="8">
                    <Border
                        Width="44"
                        Height="44"
                        HorizontalAlignment="Center"
                        Background="{StaticResource AppRaisedSurfaceBrush}"
                        BorderBrush="{StaticResource AppAccentBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                        <SymbolIcon
                            Foreground="{StaticResource AppAccentBrush}"
                            Symbol="Library"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Border>
                    <TextBlock
                        x:Name="GuideTitleLabel"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource AppTextBrush}"
                        Text="Next Gen Emby"
                        TextTrimming="CharacterEllipsis"
                        Visibility="Collapsed" />
                </StackPanel>

                <ScrollViewer
                    Grid.Row="1"
                    Margin="0,22,0,22"
                    HorizontalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Hidden"
                    VerticalScrollMode="Enabled">
                    <StackPanel Spacing="6">
                        <Button
                            x:Name="HomeButton"
                            AutomationProperties.Name="Home"
                            Click="Home_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Home" />
                                <TextBlock x:Name="HomeGuideLabel" Text="Home" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="SearchButton"
                            AutomationProperties.Name="Search"
                            Click="Search_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Find" />
                                <TextBlock x:Name="SearchGuideLabel" Text="Search" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="MoviesButton"
                            AutomationProperties.Name="Movies"
                            Click="Movies_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Video" />
                                <TextBlock x:Name="MoviesGuideLabel" Text="Movies" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="TvButton"
                            AutomationProperties.Name="Shows"
                            Click="Tv_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Library" />
                                <TextBlock x:Name="TvGuideLabel" Text="Shows" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="LiveTvButton"
                            AutomationProperties.Name="Live TV"
                            Click="LiveTv_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="World" />
                                <TextBlock x:Name="LiveTvGuideLabel" Text="Live TV" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="CollectionsButton"
                            AutomationProperties.Name="Collections"
                            Click="Collections_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Folder" />
                                <TextBlock x:Name="CollectionsGuideLabel" Text="Collections" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="PlaylistsButton"
                            AutomationProperties.Name="Playlists"
                            Click="Playlists_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="List" />
                                <TextBlock x:Name="PlaylistsGuideLabel" Text="Playlists" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="MusicButton"
                            AutomationProperties.Name="Music"
                            Click="Music_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="MusicInfo" />
                                <TextBlock x:Name="MusicGuideLabel" Text="Music" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="PhotosButton"
                            AutomationProperties.Name="Photos"
                            Click="Photos_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Pictures" />
                                <TextBlock x:Name="PhotosGuideLabel" Text="Photos" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="FavoritesButton"
                            AutomationProperties.Name="Favorites"
                            Click="Favorites_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="Favorite" />
                                <TextBlock x:Name="FavoritesGuideLabel" Text="Favorites" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                        <Button
                            x:Name="UnwatchedButton"
                            AutomationProperties.Name="Unwatched"
                            Click="Unwatched_OnClick"
                            Style="{StaticResource GuideButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <SymbolIcon Symbol="View" />
                                <TextBlock x:Name="UnwatchedGuideLabel" Text="Unwatched" VerticalAlignment="Center" Visibility="Collapsed" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <Button
                    x:Name="SettingsButton"
                    Grid.Row="2"
                    AutomationProperties.Name="Settings"
                    Click="Settings_OnClick"
                    Style="{StaticResource GuideButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="14">
                        <SymbolIcon Symbol="Setting" />
                        <TextBlock x:Name="SettingsGuideLabel" Text="Settings" VerticalAlignment="Center" Visibility="Collapsed" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <Frame
            x:Name="ContentFrame"
            Grid.Column="1"
            Background="{StaticResource AppBackgroundBrush}" />
    </Grid>
</Page>
