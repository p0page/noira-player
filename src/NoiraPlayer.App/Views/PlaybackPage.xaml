<Page
    x:Class="NoiraPlayer.App.Views.PlaybackPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppPlaybackCanvasBrush}">
    <Grid
        Background="{StaticResource AppPlaybackCanvasBrush}"
        KeyDown="Page_OnKeyDown"
        PointerPressed="Page_OnPointerPressed">
        <MediaPlayerElement
            x:Name="PlayerElement"
            AreTransportControlsEnabled="False"
            Canvas.ZIndex="0"
            Stretch="Uniform" />
        <SwapChainPanel
            x:Name="NativeSurface"
            Canvas.ZIndex="0"
            Visibility="Collapsed" />

        <Grid
            x:Name="OverlayRoot"
            Background="Transparent"
            Canvas.ZIndex="10"
            Visibility="Collapsed">
            <Border
                x:Name="PlaybackStatusCapsule"
                MaxWidth="{StaticResource TvPlaybackStatusCapsuleMaxWidth}"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Background="{StaticResource AppPlaybackOverlayBrush}"
                CornerRadius="8"
                Margin="{StaticResource TvPlaybackStatusCapsuleMargin}"
                Padding="{StaticResource TvPlaybackStatusCapsulePadding}">
                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="NowPlayingBlock"
                        FontSize="22"
                        FontWeight="SemiBold"
                        Text="Now Playing"
                        TextTrimming="CharacterEllipsis" />
                    <TextBlock
                        x:Name="StatusBlock"
                        FontSize="15"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        Text="Stopped"
                        TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <TextBlock
                x:Name="SubtitleSafeSampleBlock"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Foreground="{StaticResource AppTextBrush}"
                FontSize="24"
                FontWeight="SemiBold"
                Margin="{StaticResource TvPlaybackSubtitleSafeSampleMargin}"
                Text="Subtitle sample stays above controls"
                TextAlignment="Center"
                Visibility="Collapsed" />

            <Border
                x:Name="ManualDebugPanel"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Background="{StaticResource AppSurfaceBrush}"
                CornerRadius="8"
                Margin="{StaticResource TvPlaybackSubtitleSafeSampleMargin}"
                Padding="14"
                Visibility="Collapsed">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox
                        x:Name="StreamUrlBox"
                        Header="Direct stream URL"
                        PlaceholderText="http://server:8096/Videos/item/stream"
                        KeyDown="StreamUrlBox_OnKeyDown"
                        TextChanged="StreamUrlBox_OnTextChanged" />
                    <Button
                        x:Name="ManualStartButton"
                        Grid.Column="1"
                        AutomationProperties.Name="Play direct stream"
                        MinWidth="112"
                        VerticalAlignment="Bottom"
                        Click="Start_OnClick"
                        Style="{StaticResource TvPlaybackTransportButtonStyle}"
                        ToolTipService.ToolTip="Play direct stream">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Play" />
                            <TextBlock Text="Play" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <Border
                x:Name="PlaybackTransportStrip"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Bottom"
                Background="{StaticResource AppPlaybackOverlayBrush}"
                CornerRadius="{StaticResource TvPlaybackTransportStripCornerRadius}"
                Margin="{StaticResource TvPlaybackTransportStripMargin}"
                Padding="{StaticResource TvPlaybackTransportStripPadding}">
                <Grid RowSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid
                        x:Name="PlaybackTimelineRow"
                        Grid.Row="0"
                        ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="92" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            x:Name="CurrentTimeBlock"
                            VerticalAlignment="Center"
                            FontSize="15"
                            Foreground="{StaticResource AppMutedTextBrush}"
                            Text="0:00" />
                        <Slider
                            x:Name="ProgressSlider"
                            Grid.Column="1"
                            IsEnabled="False"
                            Maximum="1"
                            Minimum="0"
                            Value="0"
                            ValueChanged="ProgressSlider_OnValueChanged" />
                        <TextBlock
                            x:Name="DurationBlock"
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            FontSize="15"
                            Foreground="{StaticResource AppMutedTextBrush}"
                            Text="0:00" />
                    </Grid>

                    <TextBlock
                        x:Name="SeekPreviewBlock"
                        Grid.Row="0"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Foreground="{StaticResource AppMutedTextBrush}"
                        FontSize="15"
                        TextTrimming="CharacterEllipsis"
                        Visibility="Collapsed" />

                    <Grid Grid.Row="1" ColumnSpacing="18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel
                            x:Name="PlaybackCapabilityChipsPanel"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                            <Border
                                MinWidth="{StaticResource TvPlaybackTransportChipMinWidth}"
                                Background="{StaticResource AppChromeBrush}"
                                CornerRadius="6"
                                Padding="14,8">
                                <TextBlock
                                    x:Name="SourceChipBlock"
                                    FontSize="14"
                                    FontWeight="SemiBold"
                                    Text="Source"
                                    TextTrimming="CharacterEllipsis" />
                            </Border>
                            <Border
                                MinWidth="{StaticResource TvPlaybackTransportChipMinWidth}"
                                Background="{StaticResource AppChromeBrush}"
                                CornerRadius="6"
                                Padding="14,8">
                                <TextBlock
                                    x:Name="AudioChipBlock"
                                    FontSize="14"
                                    Foreground="{StaticResource AppMutedTextBrush}"
                                    Text="Audio"
                                    TextTrimming="CharacterEllipsis" />
                            </Border>
                        </StackPanel>

                        <StackPanel
                            x:Name="TransportControlsPanel"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                            <Button
                                x:Name="PauseButton"
                                AutomationProperties.Name="Pause"
                                Click="Pause_OnClick"
                                Style="{StaticResource TvPlaybackPrimaryTransportButtonStyle}"
                                ToolTipService.ToolTip="Pause playback">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Pause" />
                                    <TextBlock Text="Pause" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="ResumeButton"
                                AutomationProperties.Name="Resume"
                                Click="Resume_OnClick"
                                Style="{StaticResource TvPlaybackPrimaryTransportButtonStyle}"
                                ToolTipService.ToolTip="Resume playback">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Play" />
                                    <TextBlock Text="Resume" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="SeekBackButton"
                                AutomationProperties.Name="Seek back 10 seconds"
                                Click="SeekBack_OnClick"
                                Style="{StaticResource TvPlaybackTransportButtonStyle}"
                                ToolTipService.ToolTip="Seek backward ten seconds">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Back" />
                                    <TextBlock Text="10s" />
                                </StackPanel>
                            </Button>

                            <Button
                                x:Name="SeekForwardButton"
                                AutomationProperties.Name="Seek forward 30 seconds"
                                Click="SeekForward_OnClick"
                                Style="{StaticResource TvPlaybackTransportButtonStyle}"
                                ToolTipService.ToolTip="Seek forward thirty seconds">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Forward" />
                                    <TextBlock Text="30s" />
                                </StackPanel>
                            </Button>
                            <Button
                                x:Name="StopButton"
                                AutomationProperties.Name="Stop"
                                Click="Stop_OnClick"
                                Style="{StaticResource TvPlaybackTransportButtonStyle}"
                                ToolTipService.ToolTip="Stop playback">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="Stop" />
                                    <TextBlock Text="Stop" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                            <Border
                                MinWidth="{StaticResource TvPlaybackTransportChipMinWidth}"
                                Background="{StaticResource AppChromeBrush}"
                                CornerRadius="6"
                                Padding="14,8">
                                <TextBlock
                                    x:Name="SubtitleChipBlock"
                                    FontSize="14"
                                    Foreground="{StaticResource AppMutedTextBrush}"
                                    Text="Subtitles"
                                    TextTrimming="CharacterEllipsis" />
                            </Border>

                            <Button
                                x:Name="MoreButton"
                                AutomationProperties.Name="More"
                                Click="More_OnClick"
                                Style="{StaticResource TvPlaybackTransportButtonStyle}"
                                ToolTipService.ToolTip="More playback controls">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <SymbolIcon Symbol="More" />
                                    <TextBlock Text="More" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border
                x:Name="MoreDrawer"
                Width="{StaticResource TvPlaybackMoreMenuWidth}"
                MaxHeight="{StaticResource TvPlaybackMoreMenuMaxHeight}"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="{StaticResource AppPlaybackDrawerBrush}"
                CornerRadius="8"
                Margin="{StaticResource TvPlaybackMoreMenuMargin}"
                Padding="{StaticResource TvPlaybackMoreMenuPadding}"
                Visibility="Collapsed">
                <ScrollViewer>
                    <StackPanel
                        x:Name="MoreMenuPanel"
                        Spacing="14">
                        <TextBlock
                            Text="Playback Options"
                            FontSize="22"
                            FontWeight="SemiBold"
                            TextTrimming="CharacterEllipsis" />
                        <ComboBox
                            x:Name="SourceBox"
                            AutomationProperties.Name="Source"
                            HorizontalAlignment="Stretch"
                            Header="Source"
                            ProcessKeyboardAccelerators="MoreDrawerComboBox_OnProcessKeyboardAccelerators"
                            Style="{StaticResource TvPlaybackOptionComboBoxStyle}"
                            SelectionChanged="SourceBox_OnSelectionChanged" />
                        <ComboBox
                            x:Name="AudioStreamBox"
                            AutomationProperties.Name="Audio"
                            HorizontalAlignment="Stretch"
                            Header="Audio"
                            ProcessKeyboardAccelerators="MoreDrawerComboBox_OnProcessKeyboardAccelerators"
                            Style="{StaticResource TvPlaybackOptionComboBoxStyle}"
                            SelectionChanged="AudioStreamBox_OnSelectionChanged" />
                        <ComboBox
                            x:Name="SubtitleStreamBox"
                            AutomationProperties.Name="Subtitles"
                            HorizontalAlignment="Stretch"
                            Header="Subtitles"
                            ProcessKeyboardAccelerators="MoreDrawerComboBox_OnProcessKeyboardAccelerators"
                            Style="{StaticResource TvPlaybackOptionComboBoxStyle}"
                            SelectionChanged="SubtitleStreamBox_OnSelectionChanged" />
                        <Button
                            x:Name="InfoButton"
                            AutomationProperties.Name="Info"
                            HorizontalAlignment="Stretch"
                            Click="Info_OnClick"
                            Style="{StaticResource TvPlaybackMoreMenuButtonStyle}"
                            ToolTipService.ToolTip="Show playback information">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Help" />
                                <TextBlock Text="Info" />
                            </StackPanel>
                        </Button>
                        <Border
                            x:Name="InfoPanel"
                            Background="{StaticResource AppSurfaceBrush}"
                            Padding="14"
                            Visibility="Collapsed">
                            <TextBlock
                                x:Name="InfoBlock"
                                FontSize="15"
                                Foreground="{StaticResource AppMutedTextBrush}"
                                TextWrapping="Wrap" />
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
