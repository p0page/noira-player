<Page
    x:Class="NoiraPlayer.App.Views.PhotoViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Image
            x:Name="PhotoImage"
            Stretch="Uniform"
            ImageOpened="PhotoImage_OnOpened"
            ImageFailed="PhotoImage_OnFailed" />

        <Border Background="{StaticResource AppImmersiveScrimBrush}" />

        <Grid Margin="{StaticResource TvImmersivePageMargin}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="14">
                <Button
                    x:Name="BackButton"
                    AutomationProperties.Name="Back"
                    Click="BackButton_OnClick"
                    Style="{StaticResource IconButtonStyle}">
                    <SymbolIcon Symbol="Back" />
                </Button>
                <StackPanel
                    VerticalAlignment="Center"
                    Spacing="2">
                    <TextBlock
                        x:Name="TitleBlock"
                        Style="{StaticResource TvPageTitleTextStyle}"
                        Text="Photo" />
                    <TextBlock
                        x:Name="StatusBlock"
                        Style="{StaticResource TvPageSubtitleTextStyle}"
                        Text="Loading photo" />
                </StackPanel>
            </StackPanel>

            <Border
                x:Name="FallbackPanel"
                Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="560"
                Background="{StaticResource AppSurfaceBrush}"
                CornerRadius="8"
                Padding="{StaticResource TvPanelPadding}"
                Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <TextBlock
                        x:Name="FallbackTitleBlock"
                        Style="{StaticResource TvPanelTitleTextStyle}"
                        Text="Photo unavailable"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="FallbackBodyBlock"
                        Style="{StaticResource TvMutedBodyTextStyle}"
                        Text="This photo could not be loaded from the server."
                        TextAlignment="Center" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="2"
                HorizontalAlignment="Left"
                Background="{StaticResource AppImmersiveControlBrush}"
                CornerRadius="8"
                Padding="16,10">
                <TextBlock
                    Style="{StaticResource TvMutedBodyTextStyle}"
                    Text="B / Escape returns to the library" />
            </Border>
        </Grid>
    </Grid>
</Page>
