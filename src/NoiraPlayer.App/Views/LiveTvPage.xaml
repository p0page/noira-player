<Page
    x:Class="NoiraPlayer.App.Views.LiveTvPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{StaticResource AppBackgroundBrush}">
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid Margin="{StaticResource TvPageMargin}" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock
                        Style="{StaticResource TvPageTitleTextStyle}"
                        Text="Live TV" />
                    <TextBlock
                        x:Name="StatusBlock"
                        Style="{StaticResource TvPageSubtitleTextStyle}"
                        Text="Loading channels" />
                </StackPanel>

                <Button
                    x:Name="RefreshButton"
                    Grid.Column="1"
                    AutomationProperties.Name="Refresh live TV"
                    Click="RefreshButton_OnClick"
                    Style="{StaticResource IconButtonStyle}">
                    <SymbolIcon Symbol="Refresh" />
                </Button>
            </Grid>

            <Grid Grid.Row="1" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1120" />
                    <ColumnDefinition Width="520" />
                </Grid.ColumnDefinitions>

                <ScrollViewer
                    HorizontalScrollBarVisibility="Disabled"
                    HorizontalScrollMode="Disabled"
                    VerticalScrollBarVisibility="Hidden"
                    VerticalScrollMode="Enabled">
                    <StackPanel
                        x:Name="ChannelsPanel"
                        Spacing="10" />
                </ScrollViewer>

                <Border
                    Grid.Column="1"
                    MinHeight="220"
                    VerticalAlignment="Top"
                    Style="{StaticResource TvPanelStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock
                            Style="{StaticResource TvBadgeTextStyle}"
                            Text="Now" />
                        <Border
                            x:Name="PreviewArtworkFrame"
                            Height="190"
                            Background="{StaticResource AppRaisedSurfaceBrush}"
                            BorderBrush="{StaticResource AppTransparentBrush}"
                            BorderThickness="0"
                            CornerRadius="{StaticResource TvHomeWideCardCornerRadius}"
                            Visibility="Collapsed">
                            <Image
                                x:Name="PreviewArtworkImage"
                                Stretch="UniformToFill" />
                        </Border>
                        <TextBlock
                            x:Name="PreviewTitleBlock"
                            Style="{StaticResource TvPanelTitleTextStyle}"
                            Text="Select a channel" />
                        <TextBlock
                            x:Name="PreviewBodyBlock"
                            Style="{StaticResource TvMutedBodyTextStyle}"
                            Text="Live TV channels and current programs appear here when the server exposes them." />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid
            x:Name="FallbackPanel"
            Background="{StaticResource AppImmersiveScrimBrush}"
            Visibility="Collapsed">
            <Border
                MaxWidth="620"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Style="{StaticResource TvPanelStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Name="FallbackTitleBlock"
                        Style="{StaticResource TvPanelTitleTextStyle}"
                        Text="Live TV unavailable"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="FallbackBodyBlock"
                        Style="{StaticResource TvMutedBodyTextStyle}"
                        Text="This server did not return Live TV channels."
                        TextAlignment="Center" />
                    <Button
                        x:Name="FallbackRetryButton"
                        HorizontalAlignment="Center"
                        AutomationProperties.Name="Retry live TV"
                        Click="RefreshButton_OnClick"
                        Style="{StaticResource TvLibraryOptionSheetOptionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Refresh" />
                            <TextBlock Text="Retry" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <Grid
            x:Name="UnsupportedPanel"
            Background="{StaticResource AppImmersiveScrimBrush}"
            Visibility="Collapsed">
            <Border
                Style="{StaticResource TvTransientMessagePanelStyle}">
                <StackPanel Spacing="16">
                    <TextBlock
                        x:Name="UnsupportedTitleBlock"
                        Style="{StaticResource TvPanelTitleTextStyle}"
                        Text="Live TV playback unavailable"
                        TextAlignment="Center" />
                    <TextBlock
                        x:Name="UnsupportedBodyBlock"
                        Style="{StaticResource TvMutedBodyTextStyle}"
                        Text="Live TV browsing is available, but this build does not open live streams yet."
                        TextAlignment="Center" />
                    <Button
                        x:Name="UnsupportedCloseButton"
                        HorizontalAlignment="Center"
                        AutomationProperties.Name="Close live TV message"
                        Click="UnsupportedCloseButton_OnClick"
                        Style="{StaticResource TvLibraryOptionSheetOptionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <SymbolIcon Symbol="Back" />
                            <TextBlock Text="Close" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
